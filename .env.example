# Copy to .env locally or set these in Colab secrets/environment.
OPENROUTER_API_KEY=

# User-requested default model. If OpenRouter reports "model not found",
# replace this with the exact model slug shown in your OpenRouter account.
OPENROUTER_MODEL=gemma-4-26b-a4b-it

MMDLQA_RAW_DIR=input/raw
MMDLQA_QUESTIONS=input/sample_questions.xlsx
MMDLQA_OUTPUT_DIR=output

# Set to 0 for a cheap dry run that only builds index/retrieves evidence.
MMDLQA_USE_LLM=1
MMDLQA_USE_LLM_RERANK=1
MMDLQA_USE_VISION_LLM=1
MMDLQA_USE_WHISPER=1

# Caption every image during indexing only when needed; answer-time vision remains enabled above.
MMDLQA_USE_LLM_SUMMARIES=0
MMDLQA_WHISPER_MODEL=base
